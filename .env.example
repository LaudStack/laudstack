# ─── App ─────────────────────────────────────────────────────────────────────
# The canonical public URL of the application (used for redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=https://laudstack.com
# Alias used in some places — keep in sync with NEXT_PUBLIC_APP_URL
NEXT_PUBLIC_SITE_URL=https://laudstack.com
# Used in a few legacy references — keep in sync
NEXT_PUBLIC_BASE_URL=https://laudstack.com

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase Postgres connection string (use the pooled connection for serverless)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Optional: override the default from address
RESEND_FROM_EMAIL=LaudStack <noreply@laudstack.com>

# ─── Admin ────────────────────────────────────────────────────────────────────
# Fallback admin email for alerts when no admin users exist in the database
ADMIN_EMAIL=hello@laudstack.com

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# Secret used to authorize cron job API routes (set the same value in Vercel env)
CRON_SECRET=<generate-a-strong-random-secret>

# ─── Cloudflare ───────────────────────────────────────────────────────────────
# Cloudflare R2 credentials (if using R2 for storage)
# CLOUDFLARE_R2_ACCESS_KEY_ID=<r2-access-key>
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=<r2-secret-key>
# CLOUDFLARE_R2_BUCKET_NAME=<bucket-name>
# CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Set automatically by Vercel — do not set manually in production
# VERCEL_URL=<deployment-url>
# NODE_ENV=production
