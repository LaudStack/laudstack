# ─────────────────────────────────────────────────────────────────────────────
# LaudStack — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────

# Node environment: development | production
NODE_ENV=production

# TCP port the Express server listens on (Railway/Render inject this automatically)
PORT=3000

# Public-facing app title (used in browser tab and meta tags)
VITE_APP_TITLE=LaudStack

# ─── Database ────────────────────────────────────────────────────────────────
# MySQL/TiDB connection string (current Manus-managed DB)
# Self-hosted replacement: use a Supabase Postgres connection string or PlanetScale URL
#   Supabase:   postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#   PlanetScale: mysql://[user]:[password]@[host]/[db]?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://user:password@host:3306/laudstack

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret used to sign session cookies — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-secret

# ── Manus OAuth (current) ──
# These are only needed while using the built-in Manus OAuth provider.
# Replace with your own auth provider (Clerk, Auth.js, Supabase Auth) when self-hosting.
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=your-manus-owner-open-id

# ── Clerk (self-hosted auth replacement — recommended) ──
# Sign up at https://clerk.com, create an application, and copy the keys below.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# ── Manus Forge API (current) ──
# Used for: LLM (welcome email generation), file storage, email sending.
# These are auto-injected in the Manus environment; set them manually when self-hosting.
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ── OpenAI (self-hosted LLM replacement) ──
# Used by server/newsletter.ts for AI-generated welcome emails.
# Get your key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── Google Gemini (alternative LLM) ──
# GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── Email ───────────────────────────────────────────────────────────────────
# ── Resend (self-hosted email replacement — recommended) ──
# Replaces the Forge API email endpoint used in server/newsletter.ts.
# Sign up at https://resend.com, verify your sending domain, and create an API key.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=newsletter@yourdomain.com

# ─── File Storage ────────────────────────────────────────────────────────────
# ── AWS S3 / Supabase Storage (self-hosted storage replacement) ──
# The server/storage.ts helpers currently use the Forge storage proxy.
# Replace with direct S3 credentials when self-hosting.
# AWS S3:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=laudstack-assets
#
# Supabase Storage (uses the same S3-compatible API):
# SUPABASE_URL=https://[project].supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_STORAGE_BUCKET=laudstack-assets

# ─── Payments ────────────────────────────────────────────────────────────────
# ── Stripe ──
# Required for Featured badge upgrades, LaunchPad Pro, and Advertise placements.
# Sign up at https://stripe.com, create a product, and copy the keys below.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Analytics ───────────────────────────────────────────────────────────────
# Built-in Manus analytics (auto-injected in Manus environment)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── PostHog (self-hosted analytics replacement — recommended) ──
# Sign up at https://posthog.com
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Frontend Forge API (current — Manus only) ───────────────────────────────
# Auto-injected in Manus environment. Not needed when self-hosting.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
