{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/tools/view",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/api/tools/click",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/recalculate-rankings",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-placements",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/transition-launches",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/send-launch-notifications",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/admin-daily-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/expire-offers",
      "schedule": "0 */6 * * *"
    }
  ]
}
