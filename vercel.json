{
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "crons": [
    {
      "path": "/api/cron/recalculate-rankings",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/transition-launches",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/send-launch-notifications",
      "schedule": "0 7 * * *"
    }
  ]
}
